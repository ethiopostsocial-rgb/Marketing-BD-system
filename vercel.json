{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "nodeVersion": "22.x",
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@5.1.9"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
